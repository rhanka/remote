{
  "name": "sentropic-remote",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.14.1",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev -w @sentropic/remote-control-plane",
    "dev:ui": "npm run dev -w @sentropic/remote-operator-ui",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e:live": "vitest run e2e/live-remote-smoke.test.ts --testTimeout=240000",
    "uat:laggy": "node e2e/uat-laggy-proxy.mjs",
    "uat:rtt": "node e2e/uat-keystroke-rtt.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "harness:check": "harness check branch --profile sentropic && harness check scope --profile sentropic",
    "verify": "npm run harness:check && npm run format && npm run lint && npm run typecheck && npm run build && npm run test"
  },
  "devDependencies": {
    "@sentropic/harness": "^0.1.1",
    "@types/node": "^22.19.18",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "cookie": "^0.7.2",
    "esbuild": "^0.28.1"
  }
}
