{
  "name": "@sentropic/remote-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "remote": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/node-ws": "^1.3.1",
    "@sentropic/remote-k8s-orchestrator": "*",
    "@sentropic/remote-protocol": "*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^15.0.0",
    "hono": "^4.12.18",
    "node-pty": "^1.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  }
}
